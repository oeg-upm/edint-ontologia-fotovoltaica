@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix edintphotovusage: <http://vocab.linkeddata.es/datosabiertos/kos/edint/PhotovoltaicSystemUsageType/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

edintkos:PhotovoltaicSystemUsageType a skos:ConceptScheme ; 
    dct:issued "2026-03-23"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Tipo de uso de la instalación fotovoltaica"@en ;
    rdfs:label "Photovoltaic system usage type"@es ;
    dct:title "Concept scheme grouping types of usage of a photovoltaixc system."@en ;
    dct:title "Esquema de conceptos agrupando tipos de uso de la instalación fotovoltaica."@es .
    

#################################################################
#
#    Concepts
#
#################################################################

edintphotovusage:grid a skos:Concept;
  skos:inScheme edintkos:PhotovoltaicSystemUsageType;
  skos:prefLabel "Conectado a la red"@es ;
  skos:prefLabel "Grid"@en .

edintphotovusage:standalone a skos:Concept;
  skos:inScheme edintkos:PhotovoltaicSystemUsageType;
  skos:prefLabel "Autónomo"@es ;
  skos:prefLabel "Stand-alone"@en .

edintphotovusage:hybrid a skos:Concept;
  skos:inScheme edintkos:PhotovoltaicSystemUsageType;
  skos:prefLabel "Híbrido"@es ;
  skos:prefLabel "Hybrid"@en .







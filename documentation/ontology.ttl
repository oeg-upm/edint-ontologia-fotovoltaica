###  http://www.w3.org/2006/time#Instant
<http://www.w3.org/2006/time#Instant> rdf:type owl:Class ;
                                      rdfs:subClassOf <http://www.w3.org/2006/time#TemporalEntity> ;
                                      owl:disjointWith <http://www.w3.org/2006/time#ProperInterval> ;
                                      rdfs:comment "A temporal entity with zero extent or duration"@en ,
                                                   "Una entidad temporal con una extensión o duración cero."@es ;
                                      rdfs:label "Time instant"@en ,
                                                 "instante de tiempo."@es ;
                                      <http://www.w3.org/2004/02/skos/core#definition> "A temporal entity with zero extent or duration"@en ,
                                                                                       "Una entidad temporal con una extensión o duración cero."@es .


###  http://www.w3.org/2006/time#Interval
<http://www.w3.org/2006/time#Interval> rdf:type owl:Class ;
                                       rdfs:subClassOf <http://www.w3.org/2006/time#TemporalEntity> ;
                                       rdfs:comment "A temporal entity with an extent or duration"@en ,
                                                    "Una entidad temporal con una extensión o duración."@es ;
                                       rdfs:label "Time interval"@en ,
                                                  "intervalo de tiempo"@es ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "A temporal entity with an extent or duration"@en ,
                                                                                        "Una entidad temporal con una extensión o duración."@es .


###  http://www.w3.org/2006/time#ProperInterval
<http://www.w3.org/2006/time#ProperInterval> rdf:type owl:Class .


###  http://www.w3.org/2006/time#TemporalEntity
<http://www.w3.org/2006/time#TemporalEntity> rdf:type owl:Class ;
                                             owl:equivalentClass [ rdf:type owl:Class ;
                                                                   owl:unionOf ( <http://www.w3.org/2006/time#Instant>
                                                                                 <http://www.w3.org/2006/time#Interval>
                                                                               )
                                                                 ] ;
                                             rdfs:subClassOf owl:Thing ;
                                             rdfs:comment "A temporal interval or instant."@en ,
                                                          "Un intervalo temporal o un instante."@es ;
                                             rdfs:label "Temporal entity"@en ,
                                                        "entidad temporal"@es ;
                                             <http://www.w3.org/2004/02/skos/core#definition> "A temporal interval or instant."@en ,
                                                                                              "Un intervalo temporal o un instante."@es .


###  http://www.w3.org/ns/sosa/FeatureOfInterest
<http://www.w3.org/ns/sosa/FeatureOfInterest> rdf:type owl:Class ;
                                              rdfs:comment "Cosa cuya propiedad se está estimando o calculando en el curso de una Observación para llegar a un Resultado o cuya propiedad está siendo manipulada por un Actuador, o que está siendo muestreada o transformada en un acto de Muestreo."@es ;
                                              rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ;
                                              rdfs:label "Entidad de interés"@es ,
                                                         "Feature Of Interest"@en .


###  http://www.w3.org/ns/sosa/ObservableProperty
<http://www.w3.org/ns/sosa/ObservableProperty> rdf:type owl:Class ;
                                               rdfs:comment "Una cualidad observable (propiedad, característica) de una entidad de interés."@es ;
                                               rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ;
                                               rdfs:label "Propiedad observable"@es ,
                                                          "Observable Property" .


###  http://www.w3.org/ns/sosa/Observation
<http://www.w3.org/ns/sosa/Observation> rdf:type owl:Class ;
                                        rdfs:comment "Acto de realizar un procedimiento (de observación) para estimar o calcular el valor de una propiedad de una característica de interés. Se vincula a un sensor para describir qué realizó la observación y cómo; se vincula a una propiedad observable para describir de qué propiedad es la estimación del resultado, y a una característica de interés para detallar con qué se asoció esa propiedad."@es ;
                                        rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ;
                                        rdfs:label "Observación"@es ,
                                                   "Observation" .


###  http://www.w3.org/ns/sosa/Sensor
<http://www.w3.org/ns/sosa/Sensor> rdf:type owl:Class ;
                                   rdfs:comment "Sistema que implementa un procedimiento de observación para determinar el valor de una Propiedad observable.Puede ser un dispositivo, una infraestructura, un agente (incluyendo humanos) o software (simulación). Un sensor responde a un estímulo, por ejemplo, un cambio en el entorno o datos de entrada compuestos por los resultados de observaciones previas."@es ;
                                   rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ;
                                   rdfs:label "Sensor"@en ,
                                              "Sensor"@es .


###  https://saref.etsi.org/core/Device
<https://saref.etsi.org/core/Device> rdf:type owl:Class .


###  https://saref.etsi.org/core/Meter
<https://saref.etsi.org/core/Meter> rdf:type owl:Class ;
                                    rdfs:subClassOf <https://saref.etsi.org/core/Device> ;
                                    rdfs:comment "A device designed to observe and additionally do some computation and/or display one or more properties of one or more features of interest."@en ;
                                    rdfs:label "Meter"@en ;
                                    <http://www.w3.org/2004/02/skos/core#historyNote> "V3.2.1: Definition of Meter is simplified and grounded on saref:observes. Local restriction on saref:hasFunction is deleted."@en ,
                                                                                      "V4.1.1: Definition of Sensor and Meter are updated to better distinguish one from the other."@en .


###  https://schema.org/Organization
<https://schema.org/Organization> rdf:type owl:Class ;
                                  rdfs:comment "An organization such as a school, NGO, corporation, club, etc."@en ,
                                               "Una organización como una escuela, una ONG, una corporación, un club, etc."@es ;
                                  rdfs:label "Organización"@es ,
                                             "Organization"@en .



###  http://qudt.org/schema/qudt/applicableUnit
<http://qudt.org/schema/qudt/applicableUnit> rdf:type owl:ObjectProperty ;
                                             <http://purl.org/dc/terms/description> "See https://github.com/qudt/qudt-public-repo/wiki/Advanced-User-Guide#4-computing-applicable-units-for-a-quantitykind on how `qudt:applicableUnit` is computed from `qudt:hasQuantityKind` and then materialized"@en ;
                                             rdfs:isDefinedBy <http://qudt.org/3.1.11/schema/shacl/qudt> ,
                                                              <http://qudt.org/schema/qudt> ;
                                             rdfs:label "applicable unit" .


###  http://qudt.org/schema/qudt/hasUnit
<http://qudt.org/schema/qudt/hasUnit> rdf:type owl:ObjectProperty ;
                                      owl:inverseOf <http://qudt.org/schema/qudt/unitFor> ;
                                      <http://purl.org/dc/terms/description> "This property relates a factor unit its unit"^^rdf:HTML ,
                                                                             """This property relates a factor unit to its unit or a system of units with a unit of measure that is either 
a) defined by the system, or 
b) accepted for use by the system and is convertible to a unit of equivalent dimension that is defined by the system. 

Systems of units may distinguish between base and derived units. Base units are the units which measure the base quantities for the corresponding system of quantities. The base units are used to define units for all other quantities as products of powers of the base units. Such units are called derived units for the system."""@en ,
                                                                             """This property relates a factor unit to its unit or system of units with a unit of measure that is either:
a) defined by the system,
b) accepted for use by the system and is convertible to a unit of equivalent dimension that is defined by the system,
 c) a reference to the unit of measure of a quantity (variable or constant) of interest.
Systems of units may distinguish between base and derived units.
  Base units are the units which measure the base quantities for the corresponding system of quantities. 
  The base units are used to define units for all other quantities as products of powers of the base units. 
  Such units are called derived units for the system.""" ;
                                      rdfs:isDefinedBy <http://qudt.org/3.1.11/schema/shacl/qudt> ,
                                                       <http://qudt.org/schema/qudt> ;
                                      rdfs:label "has unit" .


###  http://qudt.org/schema/qudt/unitFor
<http://qudt.org/schema/qudt/unitFor> rdf:type owl:ObjectProperty .


###  http://schema.org/manufacturer
<http://schema.org/manufacturer> rdf:type owl:ObjectProperty ;
                                 rdfs:range <https://schema.org/Organization> ;
                                 rdfs:comment "El fabricante del producto."@es ,
                                              "The manufacturer of the product."@en ;
                                 rdfs:isDefinedBy <http://schema.org/> ;
                                 rdfs:label "fabricante"@es ,
                                            "manufacturer"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#appliesTo
:appliesTo rdf:type owl:ObjectProperty ;
           rdfs:domain :PhotovoltaicSystemContract ;
           rdfs:range :PhotovoltaicSystem ;
           rdfs:comment "Relación entre el contrato de la instalación fotovoltaica y la instalación fotovoltaica a la cual se aplica."@es ,
                        "Relationship between the photovoltaic system contract and the photovoltaic system which it applies to."@en ;
           rdfs:label "aplicadoEn"@es ,
                      "applies to"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#contractHolder
:contractHolder rdf:type owl:ObjectProperty ;
                rdfs:domain :PhotovoltaicSystemContract ;
                rdfs:range <https://schema.org/Organization> ;
                rdfs:comment "Relación entre un contrato de una instalación fotovoltaica y la organización que es titular del contrato."@es ,
                             "Relationship between a photovoltaic installation contract and the organization that holds the contract."@en ;
                rdfs:label "contract holder"@en ,
                           "titular contrato"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#hasPhotovoltaicSystem
:hasPhotovoltaicSystem rdf:type owl:ObjectProperty ;
                       rdfs:domain <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement> ;
                       rdfs:range :PhotovoltaicSystem ;
                       rdfs:comment "Relación entre un elemento de infraestructura y el sistema fotovoltaico que suministra energía al sistema eléctrico de dicho elemento. Puede estar instalado en cualquiera de las estructuras del elemento (por ejemplo, en la azotea) o en una estructura independiente (por ejemplo, en el suelo)."@es ,
                                    "Relationship between an infrastructure element and the photovoltaic system that feeds power into the elemen's electrical system. It may be installed on any of the element's structures (e.g. rooftop) or in a separate structure  (e.g., ground-mounted)."@en ;
                       rdfs:label "has photovoltaic system"@en ,
                                  "tiene instalación fotovoltaica"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#hasRate
:hasRate rdf:type owl:ObjectProperty ;
         rdfs:domain :PhotovoltaicSystemContract ;
         rdfs:range :PhotovoltaicSystemRate ;
         rdfs:comment "Relación entre un contrato de una inslación fotovoltaica y la tarifa que se aplica en dicho contrato."@es ,
                      "Relationship between a photovoltaic system contract and the rate that is applied in the contract."@en ;
         rdfs:label "has rate"@en ,
                    "tiene tarifa"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#hasStatus
:hasStatus rdf:type owl:ObjectProperty ;
           rdfs:domain :PhotovoltaicSystem ;
           rdfs:range [ rdf:type owl:Restriction ;
                        owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                        owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/PhotovoltaicSystemStatus>
                      ] ;
           rdfs:comment "Indica si el sistema está actualmente \"Operativo\", \"Parcial\" o  \"Fuera de servicio\". Estos valores están definidos en una taxonomía (esquema de conceptos SKOS)."@es ,
                        "Indicates if the system is currently \"Operative,\" \"Partial\" or \"Out of service\". These values are defined in a taxonomy (SKOS concept sheme)."@en ;
           rdfs:label "has status"@en ,
                      "tiene estado"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#hasUsageType
:hasUsageType rdf:type owl:ObjectProperty ;
              rdfs:domain :PhotovoltaicSystem ;
              rdfs:range [ rdf:type owl:Restriction ;
                           owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                           owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/PhotovoltaicSystemUsageType>
                         ] ;
              rdfs:comment """El tipo de uso se define por la conexión del sistema a la red eléctrica:
- Conectado a la red (On-Grid): Se conecta directamente a la red eléctrica, lo que permite la medición neta o la venta del excedente de energía sin necesidad de baterías.
- Autónomo (Off-Grid): Funciona de forma independiente utilizando baterías para el almacenamiento, lo que garantiza un suministro eléctrico constante.
- Híbrido: Combina la conexión a la red con el almacenamiento en baterías u otras fuentes de energía, como la eólica, ofreciendo una mayor fiabilidad.
Estos conceptos se definen en una taxonomía (esquema de conceptos SKOS)."""@es ,
                           """Usage type is defined by the connection of the system to the utility grid:
- Grid-Connected (On-Grid): Directly linked to the electrical grid, allowing for net metering or selling excess power without batteries.
- Stand-Alone (Off-Grid): Operates independently using batteries for storage to ensure a consistent power supply.
- Hybrid: Combines grid connection with battery storage or other energy sources like wind, offering enhanced reliability.
These concepts are defined in a taxonomy (SKOS concept scheme)."""@en ;
              rdfs:label "has usage type"@en ,
                         "tiene tipo uso"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#installationOrganization
:installationOrganization rdf:type owl:ObjectProperty ;
                          rdfs:domain :PhotovoltaicSystem ;
                          rdfs:range <https://schema.org/Organization> ;
                          rdfs:comment "Organización que realizó la instalación del sistema."@es ,
                                       "Organization that installed the system."@en ;
                          rdfs:label "installation organization"@en ,
                                     "organización instaladora"@es .


###  http://www.opengis.net/ont/geosparql#hasGeometry
<http://www.opengis.net/ont/geosparql#hasGeometry> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <http://www.opengis.net/ont/geosparql#Feature> ;
                                                   rdfs:range <http://www.opengis.net/ont/geosparql#Geometry> ;
                                                   rdfs:comment "Una representación espacial de un \"feature\" determinado."@es ;
                                                   rdfs:isDefinedBy <http://www.opengis.net/spec/geosparql/1.0> ;
                                                   rdfs:label "has geometry"@en ,
                                                              "tiene geometría"@es .


###  http://www.w3.org/2004/02/skos/core#inScheme
<http://www.w3.org/2004/02/skos/core#inScheme> rdf:type owl:ObjectProperty ;
                                               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core#> .


###  http://www.w3.org/2006/time#hasBeginning
<http://www.w3.org/2006/time#hasBeginning> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf <http://www.w3.org/2006/time#hasTime> ;
                                           rdfs:domain <http://www.w3.org/2006/time#TemporalEntity> ;
                                           rdfs:range <http://www.w3.org/2006/time#Instant> ;
                                           rdfs:comment "Beginning of a temporal entity"@en ,
                                                        "Comienzo de una entidad temporal."@es ;
                                           rdfs:label "has beginning"@en ,
                                                      "tiene principio"@es ;
                                           <http://www.w3.org/2004/02/skos/core#definition> "Beginning of a temporal entity."@en ,
                                                                                            "Comienzo de una entidad temporal."@es .


###  http://www.w3.org/2006/time#hasEnd
<http://www.w3.org/2006/time#hasEnd> rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf <http://www.w3.org/2006/time#hasTime> ;
                                     rdfs:domain <http://www.w3.org/2006/time#TemporalEntity> ;
                                     rdfs:range <http://www.w3.org/2006/time#Instant> ;
                                     rdfs:comment "End of a temporal entity."@en ,
                                                  "Final de una entidad temporal."@es ;
                                     rdfs:label "has end"@en ,
                                                "tiene fin"@es ;
                                     <http://www.w3.org/2004/02/skos/core#definition> "End of a temporal entity."@en ,
                                                                                      "Final de una entidad temporal."@es .


###  http://www.w3.org/2006/time#hasTime
<http://www.w3.org/2006/time#hasTime> rdf:type owl:ObjectProperty ;
                                      rdfs:range <http://www.w3.org/2006/time#TemporalEntity> ;
                                      rdfs:comment "Proporciona soporte a la asociación de una entidad temporal (instante o intervalo) a cualquier cosa."@es ,
                                                   "Supports the association of a temporal entity (instant or interval) to any thing"@en ;
                                      rdfs:label "has time"@en ,
                                                 "tiene tiempo"@es ;
                                      <http://www.w3.org/2004/02/skos/core#definition> "Proporciona soporte a la asociación de una entidad temporal (instante o intervalo) a cualquier cosa."@es ,
                                                                                       "Supports the association of a temporal entity (instant or interval) to any thing"@en ;
                                      <http://www.w3.org/2004/02/skos/core#editorialNote> "Característica arriesgada -añadida en la revisión del 2017 que no ha sido todavía utilizada de forma amplia."@es ,
                                                                                          "Feature at risk - added in 2017 revision, and not yet widely used. "@en .


###  http://www.w3.org/ns/sosa/hasFeatureOfInterest
<http://www.w3.org/ns/sosa/hasFeatureOfInterest> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <http://www.w3.org/ns/sosa/Observation> ;
                                                 rdfs:range <http://www.w3.org/ns/sosa/FeatureOfInterest> ;
                                                 rdfs:comment "Una relación entre una Observación y la entidad cuya calidad fue observada, o entre una Actuación y la entidad cuya propiedad fue modificada, o entre un acto de muestreo y la entidad que fue muestreada."@es ;
                                                 rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ;
                                                 rdfs:label "tiene entidad de interés"@es ,
                                                            "has feature of interest" .


###  http://www.w3.org/ns/sosa/hasResult
<http://www.w3.org/ns/sosa/hasResult> rdf:type owl:ObjectProperty ;
                                      owl:inverseOf <http://www.w3.org/ns/sosa/isResultOf> ;
                                      <http://schema.org/domainIncludes> <http://www.w3.org/ns/sosa/Actuation> ,
                                                                         <http://www.w3.org/ns/sosa/Observation> ,
                                                                         <http://www.w3.org/ns/sosa/ObservationCollection> ,
                                                                         <http://www.w3.org/ns/sosa/Sampling> ;
                                      <http://schema.org/rangeIncludes> <http://www.w3.org/ns/sosa/Result> ,
                                                                        <http://www.w3.org/ns/sosa/Sample> ;
                                      rdfs:comment "Relation linking an Observation or Actuation or act of Sampling and a Result or Sample."@en ;
                                      rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ,
                                                       <http://www.w3.org/ns/sosa/common/> ;
                                      rdfs:label "has result"@en ;
                                      <http://www.w3.org/2004/02/skos/core#definition> "Relation linking an Observation or Actuation or act of Sampling and a Result or Sample."@en .


###  http://www.w3.org/ns/sosa/isResultOf
<http://www.w3.org/ns/sosa/isResultOf> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/sosa/madeBySensor
<http://www.w3.org/ns/sosa/madeBySensor> rdf:type owl:ObjectProperty ;
                                         rdfs:domain <http://www.w3.org/ns/sosa/Observation> ;
                                         rdfs:range <http://www.w3.org/ns/sosa/Sensor> ;
                                         rdfs:comment "Relación entre una observación y el sensor que realiza la observación."@es ;
                                         rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ;
                                         rdfs:label "made by sensor or observer"@en ,
                                                    "realizado por sensor u observador"@es .


###  http://www.w3.org/ns/sosa/observedProperty
<http://www.w3.org/ns/sosa/observedProperty> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://www.w3.org/ns/sosa/wasObservedBy> ;
                                             rdfs:domain <http://www.w3.org/ns/sosa/Observation> ;
                                             rdfs:range <http://www.w3.org/ns/sosa/ObservableProperty> ;
                                             <http://schema.org/domainIncludes> <http://www.w3.org/ns/sosa/Observation> ,
                                                                                <http://www.w3.org/ns/sosa/ObservationCollection> ;
                                             <http://schema.org/rangeIncludes> <http://www.w3.org/ns/sosa/ObservableProperty> ,
                                                                               <http://www.w3.org/ns/sosa/Property> ;
                                             rdfs:comment "Relation linking an Observation to the property that was observed. The ObservableProperty should be a property of the FeatureOfInterest (linked by hasFeatureOfInterest) of this Observation."@en ;
                                             rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ,
                                                              <http://www.w3.org/ns/sosa/obs/> ;
                                             rdfs:label "observed property"@en ;
                                             <http://www.w3.org/2004/02/skos/core#definition> """
  relation from an Observation or ObservationCollection to the property that was observed
  """@en ,
                                                                                              "Relation linking an Observation to the property that was observed. The ObservableProperty should be a property of the FeatureOfInterest (linked by hasFeatureOfInterest) of this Observation."@en ;
                                             <http://www.w3.org/2004/02/skos/core#note> """
  'observed property' covers the concepts referred to in [VIM] as 'measurand' (quantitative values) and 'examinand' (categorical and nominal values — [VIM4]), as well as complex and structured properties whose values may be represented as lists, vectors, arrays, rasters, geometries, etc. More specific terms are used in other contexts for related concepts, such as 'analyte' (chemistry) and 'determinand' (water quality).
  """@en .


###  http://www.w3.org/ns/sosa/observes
<http://www.w3.org/ns/sosa/observes> rdf:type owl:ObjectProperty ;
                                     rdfs:domain <http://www.w3.org/ns/sosa/Sensor> ;
                                     rdfs:range <http://www.w3.org/ns/sosa/ObservableProperty> ;
                                     rdfs:comment "Relación entre un sensor y una propiedad observable que es capaz de detectar."@es ;
                                     rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ;
                                     rdfs:label "observa"@es ,
                                                "observes"@en .


###  http://www.w3.org/ns/sosa/phenomenonTime
<http://www.w3.org/ns/sosa/phenomenonTime> rdf:type owl:ObjectProperty ;
                                           <http://schema.org/domainIncludes> <http://www.w3.org/ns/sosa/Actuation> ,
                                                                              <http://www.w3.org/ns/sosa/Observation> ,
                                                                              <http://www.w3.org/ns/sosa/ObservationCollection> ,
                                                                              <http://www.w3.org/ns/sosa/Sampling> ;
                                           rdfs:comment "El momento en que el resultado de una observación, actuación o muestreo se aplica a la entidad de interés. No necesariamente coincide con el momento del resultado. Puede ser un intervalo, un instante o alguna otra entidad temporal compuesta."@es ,
                                                        "The time that the Result of an Observation, Actuation or Sampling applies to the FeatureOfInterest. Not necessarily the same as the resultTime. May be an Interval or an Instant, or some other compound TemporalEntity."@en ;
                                           rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ,
                                                            <http://www.w3.org/ns/sosa/common/> ;
                                           rdfs:label "momento del fenómeno"@es ,
                                                      "phenomenon time"@en ;
                                           <http://www.w3.org/2004/02/skos/core#definition> "The time that the Result of an Observation, Actuation or Sampling applies to the FeatureOfInterest. Not necessarily the same as the resultTime. May be an Interval or an Instant, or some other compound TemporalEntity."@en .


###  http://www.w3.org/ns/sosa/wasObservedBy
<http://www.w3.org/ns/sosa/wasObservedBy> rdf:type owl:ObjectProperty ;
                                          rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/identifier
<http://purl.org/dc/terms/identifier> rdf:type owl:DatatypeProperty ;
                                      rdfs:range rdfs:Literal ;
                                      rdfs:comment "An unambiguous reference to the resource within a given context."@en ,
                                                   "Una referencia no ambigüa al recurso dentro de un contexto determinado."@es ;
                                      rdfs:isDefinedBy <http://purl.org/dc/terms/> ;
                                      rdfs:label "identificador"@es ,
                                                 "identifier"@en .


###  http://qudt.org/schema/qudt/value
<http://qudt.org/schema/qudt/value> rdf:type owl:DatatypeProperty ;
                                    <http://purl.org/dc/terms/description> "A property to relate an observable thing with a value of any kind"^^rdf:HTML ;
                                    rdfs:isDefinedBy <http://qudt.org/schema/qudt> ;
                                    rdfs:label "value" .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#inServiceDate
:inServiceDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :PhotovoltaicSystem ;
               rdfs:range xsd:date ;
               rdfs:comment "Fecha en que se puso en servicio."@es ,
                            "Date it was put into service." ;
               rdfs:label "fecha puesta en servicio"@es ,
                          "in service date"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#installedPhotovoltaicPower
:installedPhotovoltaicPower rdf:type owl:DatatypeProperty ;
                            rdfs:domain :PhotovoltaicSystem ;
                            rdfs:range xsd:double ;
                            rdfs:comment "Capacidad nominal total de los paneles solares, medida en kilovatios (kW) o megavatios (MW), que se han instalado y conectado para generar electricidad."@es ,
                                         "Total rated capacity of solar panels, measured in kilowatts (kW) or megawatts (MW), that have been mounted and connected to generate electricity."@en ;
                            rdfs:label "installed photovoltaic power"@en ,
                                       "potencia fotovoltaica instalada"@es .


###  http://www.w3.org/2006/time#hasXSDDuration
<http://www.w3.org/2006/time#hasXSDDuration> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <http://www.w3.org/2006/time#TemporalEntity> ;
                                             rdfs:range xsd:duration ;
                                             rdfs:comment "Extensión de una entidad temporal, expresada utilizando xsd:duration."@es ,
                                                          "Extent of a temporal entity, expressed using xsd:duration"@en ;
                                             rdfs:label "has XSD duration"@en ,
                                                        "tiene duración XSD"@es ;
                                             <http://www.w3.org/2004/02/skos/core#definition> "Extensión de una entidad temporal, expresada utilizando xsd:duration."@es ,
                                                                                              "Extent of a temporal entity, expressed using xsd:duration"@en ;
                                             <http://www.w3.org/2004/02/skos/core#editorialNote> "Característica arriesgada - añadida en la revisión de 2017, y todavía no ampliamente utilizada."@es ,
                                                                                                 "Feature at risk - added in 2017 revision, and not yet widely used. "@en .


###  http://www.w3.org/2006/time#inXSDDateTimeStamp
<http://www.w3.org/2006/time#inXSDDateTimeStamp> rdf:type owl:DatatypeProperty ;
                                                 rdfs:domain <http://www.w3.org/2006/time#Instant> ;
                                                 rdfs:range xsd:dateTimeStamp ;
                                                 rdfs:comment "Posición de un instante, expresado utilizando xsd:dateTimeStamp."@es ,
                                                              "Position of an instant, expressed using xsd:dateTimeStamp"@en ;
                                                 rdfs:label "en fecha-sello de tiempo XSD"@es ,
                                                            "in XSD Date-Time-Stamp"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "Posición de un instante, expresado utilizando xsd:dateTimeStamp."@es ,
                                                                                                  "Position of an instant, expressed using xsd:dateTimeStamp"@en .


###  http://www.w3.org/2006/time#inXSDgYearMonth
<http://www.w3.org/2006/time#inXSDgYearMonth> rdf:type owl:DatatypeProperty ;
                                              rdfs:range xsd:gYearMonth ;
                                              rdfs:comment "Posición de un instante, expresado utilizando xsd:gYearMonth."@es ,
                                                           "Position of an instant, expressed using xsd:gYearMonth"@en ;
                                              rdfs:isDefinedBy <http://www.w3.org/2006/time#> ;
                                              rdfs:label "en año-mes gregoriano XSD"@es ,
                                                         "in XSD g-YearMonth"@en ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "Posición de un instante, expresado utilizando xsd:gYearMonth."@es ,
                                                                                               "Position of an instant, expressed using xsd:gYearMonth"@en .


###  http://www.w3.org/ns/sosa/hasSimpleResult
<http://www.w3.org/ns/sosa/hasSimpleResult> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <http://www.w3.org/ns/sosa/Observation> ;
                                            <http://schema.org/domainIncludes> <http://www.w3.org/ns/sosa/Actuation> ,
                                                                               <http://www.w3.org/ns/sosa/Observation> ,
                                                                               <http://www.w3.org/ns/sosa/ObservationCollection> ,
                                                                               <http://www.w3.org/ns/sosa/Sampling> ;
                                            rdfs:comment "The simple value of an Observation or Actuation or act of Sampling."@en ;
                                            rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ,
                                                             <http://www.w3.org/ns/sosa/common/> ;
                                            rdfs:label "has simple result"@en ;
                                            <http://www.w3.org/2004/02/skos/core#definition> "The simple value of an Observation or Actuation or act of Sampling."@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "For instance, the values 23 or true."@en .


###  http://www.w3.org/ns/sosa/resultTime
<http://www.w3.org/ns/sosa/resultTime> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <http://www.w3.org/ns/sosa/Observation> ;
                                       rdfs:range xsd:dateTime ;
                                       <http://schema.org/domainIncludes> <http://www.w3.org/ns/sosa/Actuation> ,
                                                                          <http://www.w3.org/ns/sosa/Observation> ,
                                                                          <http://www.w3.org/ns/sosa/ObservationCollection> ,
                                                                          <http://www.w3.org/ns/sosa/Sampling> ;
                                       rdfs:comment "The result time is the instant of time when the Observation, Actuation or Sampling activity was completed."@en ;
                                       rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ,
                                                        <http://www.w3.org/ns/sosa/common/> ;
                                       rdfs:label "result time"@en ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "The result time is the instant of time when the Observation, Actuation or Sampling activity was completed."@en .


###  https://datos.ign.es/def/geo_core#xETRS89
<https://datos.ign.es/def/geo_core#xETRS89> rdf:type owl:DatatypeProperty ;

@prefix : <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#> .

<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica> rdf:type owl:Ontology ;
                                                                                        owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica/0.1.0> ;
                                                                                        <http://purl.org/dc/terms/created> "2026-03-26" ;
                                                                                        <http://purl.org/dc/terms/creator> "Daniel Doña" ,
                                                                                                                           "Edna Ruckhaus" ,
                                                                                                                           "Lucía Sánchez" ,
                                                                                                                           "Oscar Corcho" ,
                                                                                                                           "Socorro Bernardos" ;
                                                                                        <http://purl.org/dc/terms/description> "La ontología de instalaciones fotovoltaicas describe todos los conceptos relacionados con las instalaciones de este tipo que se encuentran en los elementos de la infraestructura de un municipio y la medición de la generación, consumo, acumulación y vertido de electricidad en la red."@es ,
                                                                                                                               "The ontology of photovoltaic systems describes all the concepts related to installations of this type that are found in the elements of the infrastructure of a municipality and the measurement of the generation, consumption, accumulation and exported electricity into the grid."@en ;
                                                                                        <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                                                        <http://purl.org/dc/terms/title> "Ontología de Instalación Fotovoltaica"@es ,
                                                                                                                         "The Photovoltaic System Ontology"@en ;
                                                                                        <http://purl.org/vocab/vann/preferredNamespacePrefix> "edintfotov" ;
                                                                                        <http://purl.org/vocab/vann/preferredNamespaceUri> : ;
                                                                                        owl:versionInfo "0.1.0" .


#################################################################
#    Classes
#################################################################

###  http://qudt.org/schema/qudt/Concept
<http://qudt.org/schema/qudt/Concept> rdf:type owl:Class .


###  http://qudt.org/schema/qudt/Quantifiable
<http://qudt.org/schema/qudt/Quantifiable> rdf:type owl:Class .


###  http://qudt.org/schema/qudt/QuantityValue
<http://qudt.org/schema/qudt/QuantityValue> rdf:type owl:Class ;
                                            rdfs:subClassOf <http://qudt.org/schema/qudt/Concept> ,
                                                            <http://qudt.org/schema/qudt/Quantifiable> ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://qudt.org/schema/qudt/hasUnit> ;
                                                              owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                                            ] ;
                                            rdfs:comment "A Quantity Value  expresses the magnitude and kind of a quantity and is given by the product of a numerical value n and a unit of measure U. The number multiplying the unit is referred to as the numerical value of the quantity expressed in that unit. Refer to \"http://physics.nist.gov/Pubs/SP811/sec07.html\", NIST SP 811 section 7,  for more on quantity values."@en ;
                                            rdfs:isDefinedBy <http://qudt.org/schema/qudt> ;
                                            rdfs:label "Quantity value" .


###  http://qudt.org/schema/qudt/Unit
<http://qudt.org/schema/qudt/Unit> rdf:type owl:Class ;
                                   rdfs:subClassOf <http://qudt.org/schema/qudt/Concept> ;
                                   rdfs:comment """A unit of measure, or unit, is a particular quantity value that has been chosen as a scale for measuring other quantities of the same kind (more generally of equivalent dimension). 
  For example, the meter is a quantity of length that has been rigorously defined and standardized by the BIPM (International Board of Weights and Measures). 
  Any measurement of the length can be expressed as a number multiplied by the unit meter. 
  More formally, the value of a physical quantity Q with respect to a unit (U) is expressed as the scalar multiple of a real number (n) and U, as  Q = nU."""@en ;
                                   rdfs:isDefinedBy <http://qudt.org/schema/qudt> ;
                                   rdfs:label "Unit"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/bicicleta-publica#EstacionBicicleta
<http://vocab.ciudadesabiertas.es/def/transporte/bicicleta-publica#EstacionBicicleta> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility> ;
                                                                                      rdfs:comment "Lugar donde se puede tanto dejar como recoger las bicicletas. Está compuesto de anclajes"@es ;
                                                                                      rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/bicicleta-publica> ;
                                                                                      rdfs:label "Estación de bicicletas"@es .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo> rdf:type owl:Class ;
                                                                rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                rdfs:comment "Section/s of a Track defined by a starting and an ending Point."@en ,
                                                                             "Tramo definido por un punto de inicio y fin que puede pertenecer a una o más vías"@es ;
                                                                rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                rdfs:label "Section of Track"@en ,
                                                                           "Tramo"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                   rdfs:comment "Comunidad Autónoma o Ciudad Autónoma"@es ;
                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                   rdfs:label "Autonomía"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                rdfs:comment "Un barrio es cada una de las partes en que se dividen los pueblos grandes o sus distritos [fuente: Diccionario de la Real Academia (DRAE) 2011]"@es ;
                                                                                rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                rdfs:label "Barrio"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Ciudad
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Ciudad> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio> ;
                                                                                rdfs:comment "Una ciudad es un área urbana en la que predominan fundamentalmente la industria y los servicios [fuente: Wikipedia]"@es ;
                                                                                rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                rdfs:label "Ciudad" .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                  rdfs:comment "Un distrito es cada una de las demarcaciones en que se subdivide un territorio o una población para distribuir y ordenar el ejercicio de los derechos civiles y políticos, o de las funciones públicas, o de los servicios administrativos [fuente: Diccionario de la Real Academia (DRAE) 2011]"@es ;
                                                                                  rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                  rdfs:label "Distrito"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                   rdfs:comment """Un Municipio es el ente local definido en el artículo 140 de la Constitución española y la entidad básica de la organización territorial del Estado según el artículo 1 de la Ley 7/1985, de 2 de abril, Reguladora de las Bases del Régimen Local. Tiene personalidad jurídica y plena capacidad para el cumplimiento de sus fines. La delimitación territorial de Municipio está recogida del REgistro Central de Cartografía del IGN.
Su nombre, que se especifica con la propiedad dct:title, es el proporcionado por el Registro de Entidades Locales del Ministerio de Política Territorial, en http://www.ine.es/nomen2/index.do"""@es ;
                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                   rdfs:label "Municipio"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Provincia
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Provincia> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                   rdfs:comment """Entidad local con personalidad jurídica propia, determinada por la agrupación de Municipios y división territorial para el cumplimiento de las actividades del Estado. La delimitación territorial de Provincia está recogida en el Registro Central de Cartografía del IGN [fuente: Modelo de Direcciones de la Administración General del Estado v.2]
Su identificador, que se especifica con la propiedad dct:identifier, es el proporcionado por el INE en http://www.ine.es/daco/daco42/codmun/codmun09/09codmun.xls
Su nombre, que se especifica con la propiedad dct:title, es el proporcionado por el Registro de Entidades Locales del Ministerio de Política Territorial, en http://www.ine.es/nomen2/index.do"""@es ;
                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                   rdfs:label "Provincia" .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking> rdf:type owl:Class ;
                                                                                               rdfs:subClassOf <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility> ;
                                                                                               rdfs:comment "Aparcamiento para diferentes tipos de vehículo que incluye instalaciones o superficies de aparcamiento fuera de la vía pública o zonas de aparcamiento en la vía pública para residentes, no residentes o libres."@es ,
                                                                                                            "Parking for different types of vehicles, including off-street parking facilities or on-street parking zones for residents, non-residents, or free parking."@en ;
                                                                                               rdfs:label "Aparcamiento"@es ,
                                                                                                          "Parking"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#PhotovoltaicGeneration
:PhotovoltaicGeneration rdf:type owl:Class ;
                        rdfs:subClassOf <http://www.w3.org/ns/sosa/Observation> ;
                        rdfs:comment "Amount of electricity generated, consumed, stored and exported during a certain period of time."@en ,
                                     "Cantidad de electricidad generada, consumida, almacenada y exportada durante un período de tiempo determinado."@es ;
                        rdfs:label "Generación fotovoltaica"@es ,
                                   "Photovoltaic generation"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#PhotovoltaicMeter
:PhotovoltaicMeter rdf:type owl:Class ;
                   rdfs:subClassOf <http://www.w3.org/ns/sosa/Sensor> ,
                                   <https://saref.etsi.org/core/Meter> ;
                   rdfs:comment "Device that measures and records the total electricity produced by a solar panel system. It tracks electricity output in real-time and cumulatively (kilowatt-hours), helping to evaluate system performance, maximize efficiency, verify electricity savings, and manage grid interaction."@en ,
                                "Dispositivo que mide y registra la electricidad total producida por un sistema de paneles solares. Realiza un seguimiento de la producción de energía en tiempo real y de forma acumulativa (kilovatios-hora), lo que ayuda a evaluar el rendimiento del sistema, maximizar la eficiencia, verificar el ahorro energético y gestionar la interacción con la red eléctrica."@es ;
                   rdfs:label "Medidor fotovoltaico"@es ,
                              "Photovoltaic meter"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#PhotovoltaicSystem
:PhotovoltaicSystem rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ,
                                    <http://www.w3.org/ns/sosa/FeatureOfInterest> ;
                    rdfs:comment "A photovoltaic (PV) system, or solar power system converts sunlight directly into electricity using semiconductor materials, typically silicon, within solar panels. These systems, ranging from residential rooftops to large utility-scale power plants, consist of solar panels, inverters to convert DC to AC electricity, and mounting structures."@en ,
                                 "Un sistema fotovoltaico o sistema de energía solar, convierte la luz solar directamente en electricidad mediante materiales semiconductores, generalmente silicio, ubicados en paneles solares. Estos sistemas, que abarcan desde tejados residenciales hasta grandes centrales eléctricas, constan de paneles solares, inversores para convertir la corriente continua en corriente alterna y estructuras de montaje."@es ;
                    rdfs:label "Instalación fotovoltaica"@es ,
                               "Photovoltaic system"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#PhotovoltaicSystemContract
:PhotovoltaicSystemContract rdf:type owl:Class ;
                            rdfs:comment "Documento legalmente vinculante que describe el contrato de venta, arrendamiento o compra de energía para paneles solares."@es ,
                                         "Legally binding document outlining the sale, lease, or power purchase agreement for solar panels."@en ;
                            rdfs:label "Contrato instalación fotovoltaica"@es ,
                                       "Photovoltaic system contract"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/fotovoltaica#PhotovoltaicSystemRate
:PhotovoltaicSystemRate rdf:type owl:Class ;
                        rdfs:label "La tarifa para instalaciones fotovoltaicas es un mecanismo que remunera a los propietarios de sistemas solares por el excedente de electricidad que generan y que vierten a la red eléctrica."@es ,
                                   "Photovoltaic system rate"@en ,
                                   "Tarifa instalación fotovoltaica"@es ,
                                   "The photovoltaic system tariff is a policy mechanism that pays solar system owners for the surplus electricity they generate and feed back into the national grid."@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility> rdf:type owl:Class ;
                                                                                                   rdfs:subClassOf <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement> ;
                                                                                                   rdfs:comment "Hace referencia a edificios de servicios (públicos o privados), zonas de ocio, zonas comerciales o cualquier otro elemento  que afecte directamente a la movilidad, actuando como un foco de atracción de personas o vehículos."@es ,
                                                                                                                "It refers to service buildings (public or private), leisure areas, commercial areas or any other element that directly affects mobility, acting as a focus of attraction for persons or vehicles."@en ;
                                                                                                   rdfs:label "Equipamiento"@es ,
                                                                                                              "Facility"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement> rdf:type owl:Class ;
                                                                                                                rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                                                rdfs:comment "Representa el conjunto de todos los elementos de la infraestructura que generan movilidad y elementos urbanos tales como semáforos, señales viales, pilonas, etc."@es ,
                                                                                                                             "Represents the set of all infrastructure elements that generate mobility and urban elements such as traffic lights, road signs, bollards, etc."@en ;
                                                                                                                rdfs:label "Elemento de la infraestructura"@es ,
                                                                                                                           "Infrastructure element"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#UrbanElement
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#UrbanElement> rdf:type owl:Class ;
                                                                                                       rdfs:subClassOf <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement> ;
                                                                                                       rdfs:comment "Comprende el inventario de elementos urbanos tales como señales viales, semáforos, pilonas, etc."@es ,
                                                                                                                    "It includes the inventory of urban elements such as road signs, traffic lights, bollards, etc."@en ;
                                                                                                       rdfs:label "Elemento urbano"@es ,
                                                                                                                  "Urban element"@en .


###  http://www.opengis.net/ont/geosparql#Feature
<http://www.opengis.net/ont/geosparql#Feature> rdf:type owl:Class ;
                                               rdfs:comment "Esta clase representa el tipo \"feature\" de nivel superior. Es equivalente a GFI_Feature, definida en la norma ISO 19156:2011, y es la superclase de todos los tipos de \"feature\"."@es ;
                                               rdfs:isDefinedBy <http://www.opengis.net/spec/geosparql/1.0> ;
                                               rdfs:label "Feature"@en .


###  http://www.opengis.net/ont/geosparql#Geometry
<http://www.opengis.net/ont/geosparql#Geometry> rdf:type owl:Class ;
                                                rdfs:comment "La clase representa el tipo de geometría de nivel superior. Esta clase es equivalente a la clase UML GM_Object definida en la norma ISO 19107 y es la superclase de todos los tipos de geometría."@es ;
                                                rdfs:isDefinedBy <http://www.opengis.net/spec/geosparql/1.0> ,
                                                                 "Geometría"@es ;
                                                rdfs:label "Geometry"@en .


###  http://www.opengis.net/ont/sf#Point
<http://www.opengis.net/ont/sf#Point> rdf:type owl:Class ;
                                      rdfs:isDefinedBy <http://www.opengis.net/ont/sf#> .


